{
	"$schema": "https://oxc.rs/schema/oxfmt.json",
	"printWidth": 100,
	"semi": false,
	"singleQuote": true,
	"trailingComma": "es5",
	"bracketSpacing": true,
	"arrowParens": "avoid",
	"useTabs": true,
	"tabWidth": 4,
	"endOfLine": "lf",
	"ignorePatterns": [
		"package.json",
		"tsconfig.json",
		"node_modules",
		"dist",
		"build",
		"*.lock",
		".github",
		"README.md",
		"LICENSE",
	],
}
